# ─────────────────────────────────────────────
#  Scanarr — Environment Configuration
#  Copy this file to .env and edit the values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── Paths (Docker volumes) ──────────────────
CONFIG_DIR=/config          # DB, keys, covers
DATA_DIR=/manga             # Root library folder

# ── Authentication ───────────────────────────
# Set to "true" to require login
AUTH_REQUIRED=true
AUTH_USERNAME=admin
# Bcrypt hash of your password. Generate with:
#   python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('yourpassword'))"
AUTH_PASSWORD_HASH=

# ── Application ──────────────────────────────
LOG_LEVEL=info              # debug | info | warning | error
DEBUG=false
PORT=8080

# ── CORS (comma-separated origins for dev) ───
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Scheduler ────────────────────────────────
# How often (minutes) to poll RSS feeds for new chapters
RSS_POLL_INTERVAL=60
# How often (seconds) to sync the download queue status
QUEUE_SYNC_INTERVAL=30
# How often (hours) to refresh manga metadata from MangaDex
METADATA_REFRESH_INTERVAL=24
